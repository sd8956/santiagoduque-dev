{
  "name": "santiagoduque-dev",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Blog personal y portafolio profesional de Santiago Duque.",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "tsx scripts/generate-og.ts",
    "build": "astro build",
    "postbuild": "pagefind --site dist",
    "preview": "pnpm run build && wrangler dev",
    "astro": "astro",
    "typecheck": "astro check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "new-post": "tsx scripts/new-post.ts",
    "new-project": "tsx scripts/new-project.ts",
    "generate-types": "wrangler types",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.3.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.2.1",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.16.0",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.3.1",
    "gray-matter": "^4.0.3",
    "pagefind": "^1.5.2",
    "prettier": "^3.4.1",
    "prettier-plugin-astro": "^0.14.1",
    "satori": "^0.26.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.87.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "overrides": {
    "vite": "^7"
  }
}
