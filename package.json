{
  "name": "santiagoduque-dev",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Blog personal y portafolio profesional de Santiago Duque.",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "tsx scripts/generate-og.ts",
    "build": "astro build",
    "postbuild": "pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "new-post": "tsx scripts/new-post.ts",
    "new-project": "tsx scripts/new-project.ts"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.2.1",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.3.1",
    "gray-matter": "^4.0.3",
    "pagefind": "^1.5.2",
    "prettier": "^3.4.1",
    "prettier-plugin-astro": "^0.14.1",
    "satori": "^0.26.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
