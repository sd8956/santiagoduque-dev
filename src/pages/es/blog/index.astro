---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';
import PostCard from '../../../components/blog/PostCard.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import { site } from '../../../data/site';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const posts = (
  await getCollection('blog', (entry) => entry.data.language === lang && !entry.data.draft)
).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const alternates = [
  { lang: 'es', href: `${site.url}/es/blog/` },
  { lang: 'en', href: `${site.url}/en/blog/` },
];
---

<PageLayout title={t.blog.title} alternates={alternates}>
  <h1 class="text-3xl font-bold text-fg">{t.blog.title}</h1>

  {
    posts.length === 0 ? (
      <p class="mt-8 text-muted">{t.blog.empty}</p>
    ) : (
      <div class="mt-8">
        {posts.map((post) => {
          const cleanSlug = post.slug.replace(/^(es|en)\//, '');
          return (
            <PostCard
              slug={cleanSlug}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
            />
          );
        })}
      </div>
    )
  }
</PageLayout>
