---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BlogLayout from '../../../layouts/BlogLayout.astro';
import { readingTimeMinutes } from '../../../utils/readingTime';
import { site } from '../../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection(
    'blog',
    (entry) => entry.data.language === 'en' && !entry.data.draft,
  );
  return posts.map((post) => {
    const slug = post.id.split('/').at(-1) ?? post.id;
    return {
      params: { slug },
      props: { post },
    };
  });
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const readingMinutes = readingTimeMinutes(post.body ?? '');

const slug = post.id.split('/').at(-1) ?? post.id;
const ogImage = `/og/${slug}.png`;
const alternates = post.data.translatedTo
  ? [
      { lang: 'en', href: `${site.url}/en/blog/${slug}/` },
      { lang: 'es', href: `${site.url}/es/blog/${post.data.translatedTo}/` },
    ]
  : [{ lang: 'en', href: `${site.url}/en/blog/${slug}/` }];
const alternatePath = post.data.translatedTo ? `/es/blog/${post.data.translatedTo}/` : '/es/blog/';
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  tags={post.data.tags}
  readingMinutes={readingMinutes}
  ogImage={ogImage}
  alternates={alternates}
  alternatePath={alternatePath}
  headings={headings}
>
  <Content />
</BlogLayout>
