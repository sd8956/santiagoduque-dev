---
import '../styles/global.css';
import { getLangFromUrl } from '../i18n/utils';
import { site } from '../data/site';

interface Alternate {
  lang: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  alternates?: Alternate[];
}

const lang = getLangFromUrl(Astro.url);
const {
  title,
  description = site.description[lang],
  ogImage = '/og-default.png',
  canonicalUrl = new URL(Astro.url.pathname, site.url).toString(),
  alternates = [],
} = Astro.props;

const fullTitle = title === site.name ? title : `${title} — ${site.name}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <script is:inline>
      // FOUC-prevention: set theme attribute before paint based on saved
      // preference, falling back to prefers-color-scheme.
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          var theme = saved || (matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
          if (theme === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
          }
        } catch (e) {
          /* localStorage may be blocked */
        }
      })();
    </script>

    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {alternates.map((a) => <link rel="alternate" hreflang={a.lang} href={a.href} />)}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, site.url).toString()} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.name} (${lang})`}
      href={`/${lang}/rss.xml`}
    />

    <link
      rel="preload"
      href="/fonts/JetBrainsMono-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body>
    <slot />
  </body>
</html>
