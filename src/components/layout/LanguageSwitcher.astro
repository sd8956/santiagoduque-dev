---
import { switchLangPath, useTranslations } from '../../i18n/utils';
import type { Locale } from '../../i18n/config';

interface Props {
  currentLang: Locale;
  currentPath: string;
}

const { currentLang, currentPath } = Astro.props;
const otherLang: Locale = currentLang === 'es' ? 'en' : 'es';
const targetPath = switchLangPath(currentPath, otherLang);
const t = useTranslations(currentLang);
---

<a
  href={targetPath}
  aria-label={t.common.switchLangAria}
  class="-m-2 inline-flex min-h-11 min-w-11 items-center justify-center p-2 text-muted transition-colors hover:text-accent"
>
  {t.common.switchLang}
</a>
