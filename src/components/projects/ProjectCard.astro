---
interface Props {
  title: string;
  description: string;
  techStack: string[];
  githubUrl?: string;
  demoUrl?: string;
  blogPostUrl?: string;
  blogPostLabel?: string;
}

const { title, description, techStack, githubUrl, demoUrl, blogPostUrl, blogPostLabel } =
  Astro.props;
const hasLinks = Boolean(githubUrl || demoUrl || blogPostUrl);
---

<article class="border-b border-line py-6">
  <h2 class="text-xl font-bold text-fg">{title}</h2>
  <p class="mt-2 text-muted">{description}</p>
  <ul class="mt-3 flex flex-wrap gap-2 text-xs">
    {
      techStack.map((tech) => (
        <li class="rounded border border-line px-2 py-0.5 text-muted">{tech}</li>
      ))
    }
  </ul>
  {
    hasLinks && (
      <div class="mt-3 flex flex-wrap gap-4 text-sm">
        {githubUrl && (
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener"
            class="text-accent underline underline-offset-4 transition-opacity hover:opacity-80"
          >
            → github
          </a>
        )}
        {demoUrl && (
          <a
            href={demoUrl}
            target="_blank"
            rel="noopener"
            class="text-accent underline underline-offset-4 transition-opacity hover:opacity-80"
          >
            → demo
          </a>
        )}
        {blogPostUrl && blogPostLabel && (
          <a
            href={blogPostUrl}
            class="text-accent underline underline-offset-4 transition-opacity hover:opacity-80"
          >
            → {blogPostLabel}
          </a>
        )}
      </div>
    )
  }
</article>
